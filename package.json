{
  "name": "quai-emissions-db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "validate:env": "tsx scripts/validate-env.ts",
    "doctor": "tsx scripts/doctor.ts",
    "deploy:check": "tsx scripts/deploy/check.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "migrate": "npm run validate:env && tsx --env-file=.env.local scripts/migrate.ts",
    "reset:db": "tsx --env-file=.env.local scripts/reset-db.ts",
    "ingest": "tsx --env-file=.env.local scripts/ingest/run.ts",
    "backfill": "tsx --env-file=.env.local scripts/ingest/backfill.ts",
    "backfill:workshares": "tsx --env-file=.env.local scripts/ingest/backfill-workshares.ts",
    "backfill:coinbase-rewards": "tsx --env-file=.env.local scripts/ingest/backfill-coinbase-rewards.ts",
    "backfill:network-activity": "tsx --env-file=.env.local scripts/ingest/backfill-coinbase-rewards.ts",
    "backfill:qi-market": "tsx --env-file=.env.local scripts/ingest/backfill-qi-market.ts",
    "backfill:smoke": "tsx --env-file=.env.local scripts/ingest/backfill.ts --limit=1000",
    "rollup": "tsx --env-file=.env.local scripts/ingest/rollup.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.5",
    "clsx": "^2.1.1",
    "lucide-react": "^0.456.0",
    "next": "^16.2.6",
    "pg": "^8.13.1",
    "quais": "^1.0.0-alpha.30",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
