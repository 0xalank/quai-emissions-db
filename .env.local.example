# --- Quai RPC ---
# Single zone JSON-RPC endpoint for ingest/backfill methods.
#
# Options (path-based, zone-suffixed):
#   - https://debug.rpc.quai.network/cyprus1  (has PR 2696: historical getMiningInfo)
#   - https://rpc.quai.network/cyprus1         (stable public gateway, current-tip only)
#
# For a local dev node, use the bare port (e.g. http://10.0.0.12:9200).
# When unset, defaults to `https://rpc.quai.network/${NEXT_PUBLIC_QUAI_ZONE}`.
QUAI_ZONE_RPC=https://debug.rpc.quai.network/cyprus1

# Public/current-tip RPC for live dashboard KPIs. May be provided as the bare
# gateway base URL or zone URL. When unset, defaults to:
# `https://rpc.quai.network/${NEXT_PUBLIC_QUAI_ZONE}`.
QUAI_PUBLIC_RPC=https://rpc.quai.network

NEXT_PUBLIC_QUAI_ZONE=cyprus1

# Enables the /history chart grid. When false, /history shows a placeholder card
# instead of fetching rollups. Flip to "true" once /api/rollups is healthy.
NEXT_PUBLIC_ROLLUPS_ENABLED=true

# Canonical public URL for OpenGraph/Twitter image URLs. Optional locally.
# NEXT_PUBLIC_SITE_URL=https://dashboard.example.com

# Optional local-dev shortcut. When set, local API route handlers proxy to this
# deployed dashboard API instead of reading local Postgres.
# UPSTREAM_API_BASE_URL=https://supply.qu.ai

# Optional. Used by /api/pow-markets for PoW comparison prices. The route also
# attempts CoinGecko's public demo endpoint when unset, but a key improves
# reliability under normal dashboard traffic.
# COINGECKO_DEMO_API_KEY=
# COINGECKO_PRO_API_KEY=

# --- Postgres ---
# Connection URL for the emissions Postgres. Used by migrations, the ingest
# worker, and the Next.js app.
#
# Local Docker compose default:
# DATABASE_URL=postgresql://quai_emissions:quai_emissions_dev@127.0.0.1:5433/quaiemissions
#
# For production, point at a managed Postgres (Supabase/Neon/RDS) and include
# ?sslmode=require.
DATABASE_URL=postgresql://user:CHANGE_ME@host:5432/quaiemissions?sslmode=require
